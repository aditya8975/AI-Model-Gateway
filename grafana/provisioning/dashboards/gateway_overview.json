{
  "title": "AI Model Gateway",
  "uid": "ai-model-gateway",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Task Type (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (task_type) (rate(gateway_requests_total[1m]))",
          "legendFormat": "{{task_type}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(gateway_requests_total{status_code=~\"4..|5..\"}[5m])) / sum(rate(gateway_requests_total[5m]))",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "p50 / p95 / p99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (task_type) (gateway_inflight_requests)",
          "legendFormat": "{{task_type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "gateway_queue_depth", "legendFormat": "pending jobs" }
      ]
    },
    {
      "id": 6,
      "title": "Rate Limit Rejections (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "expr": "sum(increase(gateway_rate_limit_rejections_total[5m]))", "legendFormat": "429s" }
      ]
    },
    {
      "id": 7,
      "title": "Auth Failures (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "expr": "sum(increase(gateway_auth_failures_total[5m]))", "legendFormat": "401s" }
      ]
    }
  ]
}
