# Copy this file to .env and adjust as needed.
# docker-compose.yml reads these values automatically.

# ---------------- Postgres ----------------
POSTGRES_PASSWORD=gateway

# ---------------- Admin ----------------
# Master key for /v1/admin/* endpoints (creating/revoking API keys).
# CHANGE THIS before deploying anywhere real.
ADMIN_MASTER_KEY=change-me-admin-master-key

# ---------------- Logging ----------------
LOG_LEVEL=INFO

# ---------------- Public ports ----------------
GATEWAY_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---------------- Upstream AI providers (all optional) ----------------
# If left blank, each backend automatically falls back to a functional
# mock/local implementation so the whole gateway works out-of-the-box
# with zero external credentials. OCR always uses real local Tesseract.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ASR_PROVIDER_API_KEY=
TTS_PROVIDER_API_KEY=
VISION_PROVIDER_API_KEY=
